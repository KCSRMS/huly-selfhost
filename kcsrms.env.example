# Copy to kcsrms.env and fill in secrets. Do not commit kcsrms.env.
# Local: docker compose --env-file kcsrms.env up -d
# Dokploy: sync these keys/values into the project environment (or paste from kcsrms.env).

HULY_VERSION=v0.7.375
DESKTOP_CHANNEL=0.7.375
DOCKER_NAME=huly_v7

# Used by notification service as SOURCE= (web push sender id) and later by mail SOURCE=.
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

GITHUB_APPID=
GITHUB_APPNAME=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

LIVEKIT_HOST=
LIVEKIT_WS=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

#DISABLE_SIGNUP=true

# The address of the host or server from which you will access your Huly instance.
# This can be a domain name (e.g., huly.example.com) or an IP address (e.g., 192.168.1.1).
HOST_ADDRESS=

# Set this variable to 'true' to enable SSL (HTTPS/WSS).
# Leave it empty to use non-SSL (HTTP/WS).
SECURE=true

# Specify the IP address to bind to; leave blank to bind to all interfaces (0.0.0.0).
# Do not use IP:PORT format in HTTP_BIND or HTTP_PORT.
HTTP_PORT=80
HTTP_BIND=

# Huly specific variables
TITLE=Huly
DEFAULT_LANGUAGE=en
LAST_NAME_FIRST=true

# Web Push (VAPID) — generated via: npx web-push generate-vapid-keys
# Used by transactor + front; public/private mapped to notification PUSH_PUBLIC_KEY / PUSH_PRIVATE_KEY in compose.yml.
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:you@example.com

# CockroachDB variables
CR_DATABASE=defaultdb
CR_USERNAME=selfhost
CR_USER_PASSWORD=
CR_DB_URL=

# Redpanda variables
REDPANDA_ADMIN_USER=superadmin
REDPANDA_ADMIN_PWD=

# Docker volume paths - specify custom paths for persistent data storage
# Leave empty to use default Docker named volumes
VOLUME_ELASTIC_PATH=
VOLUME_FILES_PATH=
VOLUME_CR_DATA_PATH=
VOLUME_CR_CERTS_PATH=
VOLUME_REDPANDA_PATH=

# The following configs are auto-generated by the setup script.
# Please do not manually overwrite.

# Run with --secret to regenerate.
SECRET=
